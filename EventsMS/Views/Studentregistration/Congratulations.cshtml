

<!-- Optional: Include lightweight confetti library (CDN) for enhanced celebration -->
<script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1"></script>

 @model EventsMS.Models.CongratulationsViewModel
@{
    Layout = "_PublicLayout";
    ViewData["Title"] = "Congratulations!";
    var eventName = ViewData["EventName"]?.ToString() ?? "the event";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-9 col-md-11">

            <!-- Hero Success Section -->
            <div class="text-center mb-5 position-relative">
                <!-- Floating Confetti Background Effect -->
                <div class="confetti-container"></div>

                <div class="mb-4">
                    <span class="display-1 fw-light" style="font-size: 6rem; animation: bounce 1.5s ease;">🎉</span>
                </div>

                <h1 class="display-3 fw-bold text-success mb-3" style="letter-spacing: -1px;">
                    Congratulations!
                </h1>

                <p class="lead fs-2 text-muted mb-4">
                    You have successfully registered for
                </p>

                <h2 class="display-5 fw-semibold text-primary mb-5">
                    @eventName
                </h2>

                <!-- Success Message -->
                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show shadow-sm mx-auto"
                         style="max-width: 600px;" role="alert">
                        <i class="bi bi-check-circle-fill me-2 fs-4"></i>
                        @TempData["SuccessMessage"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }
            </div>

            <div class="row g-4">
                <!-- Registration Card -->
                <div class="col-lg-7">
                    <div class="card shadow-lg border-0 h-100 overflow-hidden">
                        <div class="card-header bg-gradient text-white py-4">
                            <h5 class="mb-0 fs-4">
                                <i class="bi bi-person-check-fill me-3"></i>
                                Registration Details
                            </h5>
                        </div>
                        <div class="card-body p-5">
                            <div class="row g-4">
                                <div class="col-md-6">
                                    <div class="d-flex align-items-center gap-3">
                                        <i class="bi bi-person-fill fs-1 text-primary"></i>
                                        <div>
                                            <small class="text-muted">Full Name</small>
                                            <p class="fs-4 fw-semibold mb-0">@Model.Registration.FullName</p>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="d-flex align-items-center gap-3">
                                        <i class="bi bi-envelope-fill fs-1 text-info"></i>
                                        <div>
                                            <small class="text-muted">Email Address</small>
                                            <p class="fs-5 fw-medium mb-0">@Model.Registration.Email</p>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-12">
                                    <div class="d-flex align-items-center gap-3">
                                        <i class="bi bi-telephone-fill fs-1 text-success"></i>
                                        <div>
                                            <small class="text-muted">Phone Number</small>
                                            <p class="fs-4 fw-semibold mb-0">@Model.Registration.PhoneNumber</p>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Payment Card -->
                @if (Model.Payment != null)
                {
                    <div class="col-lg-5">
                        <div class="card shadow-lg border-0 h-100 overflow-hidden">
                            <div class="card-header bg-success text-white py-4">
                                <h5 class="mb-0 fs-4">
                                    <i class="bi bi-check-circle-fill me-3"></i>
                                    Payment Successful
                                </h5>
                            </div>
                            <div class="card-body p-5">
                                <div class="text-center mb-4">
                                    <span class="badge bg-success fs-5 px-4 py-2 rounded-pill">
                                        PAID
                                    </span>
                                </div>

                                <div class="border rounded-4 p-4 bg-light mb-4">
                                    <div class="d-flex justify-content-between mb-3">
                                        <span class="text-muted">Invoice No.</span>
                                        <strong>#@Model.Payment.InvoiceNumber</strong>
                                    </div>
                                    <div class="d-flex justify-content-between mb-3">
                                        <span class="text-muted">Amount Paid</span>
                                        <strong class="text-success fs-4">@Model.Payment.Amount.ToString("C0")</strong>
                                    </div>
                                    <div class="d-flex justify-content-between">
                                        <span class="text-muted">Transaction ID</span>
                                        <strong class="text-muted">@(string.IsNullOrEmpty(Model.Payment.TransactionId) ? "—" : Model.Payment.TransactionId)</strong>
                                    </div>
                                </div>

                                <a asp-controller="Payment"
                                   asp-action="DownloadReceipt"
                                   asp-route-id="@Model.Payment.Id"
                                   class="btn btn-success btn-lg w-100 py-3 rounded-pill shadow-sm">
                                    <i class="bi bi-download me-2"></i>
                                    Download Receipt (PDF)
                                </a>
                            </div>
                        </div>
                    </div>
                }
                else
                {
                    <div class="col-12">
                        <div class="alert alert-warning shadow border-0 p-4">
                            <i class="bi bi-info-circle me-2"></i>
                            Payment details will appear here once the transaction is completed.
                        </div>
                    </div>
                }
            </div>

            <!-- Action Buttons -->
            <div class="text-center mt-5">
                <a asp-controller="Home" asp-action="Index"
                   class="btn btn-primary btn-lg px-5 py-3 rounded-pill me-3 shadow">
                    <i class="bi bi-house-door-fill me-2"></i> Back to Events
                </a>

                @if (Model.Payment != null)
                {
                    <button onclick="addToCalendar()"
                            class="btn btn-outline-primary btn-lg px-5 py-3 rounded-pill shadow">
                        <i class="bi bi-calendar-plus me-2"></i> Add to Calendar
                    </button>
                }
            </div>

            <div class="text-center mt-4">
                <p class="text-muted">
                    We're excited to have you join us!<br>
                    <small>Thank you for being part of @eventName</small>
                </p>
            </div>

        </div>
    </div>
</div>

<!-- Custom CSS + Animations -->
<style>
    .confetti-container {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        pointer-events: none;
        z-index: -1;
        overflow: hidden;
    }

    @@keyframes bounce {
        0%, 100%

    {
        transform: translateY(0);
    }

    50% {
        transform: translateY(-20px);
    }

    }

    .card {
        border-radius: 20px;
        transition: all 0.3s ease;
    }

        .card:hover {
            transform: translateY(-8px);
            box-shadow: 0 20px 40px rgba(0,0,0,0.1) !important;
        }

    .card-header {
        background: linear-gradient(135deg, #0d6efd, #0a58ca) !important;
    }

    .display-3 {
        font-weight: 700;
        background: linear-gradient(to right, #198754, #0d6efd);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .btn-rounded-pill {
        border-radius: 50px;
        font-weight: 600;
    }
</style>

<!-- Optional: Simple Confetti JS (Add this if you want real confetti) -->
<script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.6.0/dist/confetti.browser.min.js"></script>
<script>
    // Trigger confetti on page load
    window.onload = function() {
        confetti({
            particleCount: 150,
            spread: 70,
            origin: { y: 0.6 }
        });
    };

    function addToCalendar() {
        alert("Calendar integration coming soon! 🎯");
        // You can later integrate Google Calendar / ICS download here
    }
</script> 


@* @model EventsMS.Models.CongratulationsViewModel
@{
