<style>
    /* Professional design enhancements */
    @@import url('https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700&display=swap');

    .registration-success-wrapper {
        font-family: 'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
        background: linear-gradient(135deg, #f5f7fa 0%, #e9edf2 100%);
        min-height: 100vh;
    }

    /* Success animation */
    .success-animation {
        display: inline-flex;
        justify-content: center;
        align-items: center;
    }

    .checkmark-circle {
        width: 80px;
        height: 80px;
        display: block;
    }

    .checkmark-circle-bg {
        stroke-dasharray: 166;
        stroke-dashoffset: 166;
        animation: stroke-bg 0.6s cubic-bezier(0.65, 0, 0.45, 1) forwards;
    }

    .checkmark-check {
        stroke-dasharray: 48;
        stroke-dashoffset: 48;
        animation: stroke-check 0.4s cubic-bezier(0.65, 0, 0.45, 1) 0.3s forwards;
    }

    @@keyframes stroke-bg {
        100%

    {
        stroke-dashoffset: 0;
    }

    }

    @@keyframes stroke-check {
        100%

    {
        stroke-dashoffset: 0;
    }

    }

    /* Text gradient */
    .text-gradient {
        background: linear-gradient(135deg, #10b981 0%, #059669 100%);
        background-clip: text;
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    /* Gradient backgrounds */
    .bg-gradient-primary {
        background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);
    }

    .bg-gradient-success {
        background: linear-gradient(135deg, #10b981 0%, #059669 100%);
    }

    /* Card styling */
    .card {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

        .card:hover {
            transform: translateY(-2px);
            box-shadow: 0 20px 30px -12px rgba(0, 0, 0, 0.15) !important;
        }

    /* Info items */
    .info-item {
        margin-bottom: 0.5rem;
    }

    .info-label {
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        font-weight: 600;
        color: #6c757d;
        margin-bottom: 0.25rem;
    }

    .info-value {
        font-size: 1rem;
        color: #1e293b;
        word-break: break-word;
    }

    /* Copy button */
    .btn-copy-icon {
        background: transparent;
        border: none;
        color: #94a3b8;
        padding: 0 0 0 8px;
        font-size: 0.85rem;
        cursor: pointer;
        transition: color 0.2s;
        vertical-align: middle;
    }

        .btn-copy-icon:hover {
            color: #10b981;
        }

    /* Step icons */
    .step-icon {
        width: 32px;
        height: 32px;
        background: linear-gradient(135deg, #10b981 0%, #059669 100%);
        color: white;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
        font-size: 0.9rem;
    }

    /* Button gradients */
    .btn-gradient-success {
        background: linear-gradient(135deg, #10b981 0%, #059669 100%);
        border: none;
        color: white;
        transition: all 0.2s;
        box-shadow: 0 4px 12px rgba(16, 185, 129, 0.3);
    }

        .btn-gradient-success:hover {
            transform: translateY(-1px);
            box-shadow: 0 6px 16px rgba(16, 185, 129, 0.4);
            color: white;
            background: linear-gradient(135deg, #059669 0%, #047857 100%);
        }

    /* Print styles */
    @@media print {
        .registration-success-wrapper

    {
        background: white;
        padding: 0;
    }

    .btn, .btn-copy-icon, .alert-dismissible .btn-close, .card-header .bg-opacity-25 {
        display: none !important;
    }

    .card {
        box-shadow: none !important;
        border: 1px solid #dee2e6 !important;
        transform: none !important;
    }

    .text-gradient {
