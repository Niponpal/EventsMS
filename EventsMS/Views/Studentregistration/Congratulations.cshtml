@model EventsMS.Models.CongratulationsViewModel
@{
    Layout = "_PublicLayout";
    ViewData["Title"] = "Congratulations!";
    var eventName = ViewData["EventName"]?.ToString() ?? "the event";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8 col-md-10">

            <!-- Success Header -->
            <div class="text-center mb-5">
                <div class="mb-4">
                    <span class="display-1">🎉</span>
                </div>
                <h1 class="display-4 fw-bold text-success">Congratulations!</h1>
                <p class="lead fs-3">
                    You have successfully registered for <strong>@eventName</strong>
                </p>

                <!-- Show success message from TempData -->
                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show mt-4" role="alert">
                        <i class="bi bi-check-circle-fill me-2"></i>
                        @TempData["SuccessMessage"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }
            </div>

            <!-- Registration Details -->
            <div class="card shadow border-0 mb-4">
                <div class="card-header bg-primary text-white py-3">
                    <h5 class="mb-0">
                        <i class="bi bi-person-circle me-2"></i>
                        Student Registration Details
                    </h5>
                </div>
                <div class="card-body p-4">
                    <div class="row">
                        <div class="col-md-4">
                            <p class="text-muted mb-1"><strong>Full Name</strong></p>
                            <p class="fs-5">@Model.Registration.FullName</p>
                        </div>
                        <div class="col-md-4">
                            <p class="text-muted mb-1"><strong>Email</strong></p>
                            <p class="fs-5">@Model.Registration.Email</p>
                        </div>
                        <div class="col-md-4">
                            <p class="text-muted mb-1"><strong>Phone</strong></p>
                            <p class="fs-5">@Model.Registration.PhoneNumber</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Payment Details -->
            @if (Model.Payment != null)
            {
                <div class="card shadow border-0 mb-4">
                    <div class="card-header bg-success text-white py-3">
                        <h5 class="mb-0">
                            <i class="bi bi-credit-card-fill me-2"></i>
                            Payment Information
                        </h5>
                    </div>
                    <div class="card-body p-4">
                        <div class="row g-4">
                            <div class="col-md-6">
                                <p><strong>Invoice Number:</strong> <span class="fw-bold">#@Model.Payment.InvoiceNumber</span></p>
                                <p><strong>Amount Paid:</strong> <span class="fw-bold text-success">@Model.Payment.Amount.ToString("C0")</span></p>
                            </div>
                            <div class="col-md-6">
                                <p>
                                    <strong>Status:</strong>
                                    <span class="badge bg-success fs-6">@Model.Payment.Status</span>
                                </p>
                                <p><strong>Provider:</strong> @Model.Payment.Provider</p>
                                <p>
                                    <strong>Transaction ID:</strong>
                                    @if (!string.IsNullOrEmpty(Model.Payment.TransactionId))
                                    {
                                        <span class="text-muted">@Model.Payment.TransactionId</span>
                                    }
                                    else
                                    {
                                        <span class="text-warning">—</span>
                                    }
                                </p>
                            </div>
                        </div>

                        <hr class="my-4">

                        <a asp-controller="Payment"
                           asp-action="DownloadReceipt"
                           asp-route-id="@Model.Payment.Id"
                           class="btn btn-outline-success btn-lg px-4 rounded-pill">
                            <i class="bi bi-download me-2"></i>
                            Download Receipt (PDF/TXT)
                        </a>
                    </div>
                </div>
            }
            else
            {
                <div class="alert alert-warning shadow-sm">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                    Payment details are not available yet. Please complete the payment if required.
                </div>
            }

            <!-- Action Buttons -->
            <div class="text-center mt-5">
                <a asp-controller="Home"
                   asp-action="Index"
                   class="btn btn-primary btn-lg px-5 rounded-pill me-3">
                    <i class="bi bi-house-door me-2"></i> Back to Events
                </a>

                @if (Model.Payment != null)
                {
                    <a href="#"
                       class="btn btn-outline-secondary btn-lg px-5 rounded-pill">
                        <i class="bi bi-calendar-plus me-2"></i> Add to Calendar
                    </a>
                }
            </div>

            <div class="text-center mt-4 text-muted small">
                Thank you for choosing our event. We look forward to seeing you there!
            </div>

        </div>
    </div>
</div>

<!-- Optional: Custom CSS -->
<style>
    .card {
        border-radius: 16px;
        overflow: hidden;
    }

    .card-header {
        font-weight: 600;
    }

    .lead {
        color: #555;
    }

    .btn-rounded-pill {
        border-radius: 50px;
        padding: 12px 32px;
    }

    .display-1 {
        font-size: 4.5rem;
    }
</style>