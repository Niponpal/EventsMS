@model EventsMS.Models.Auth.RegisterViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Join EventsMS - Create Account</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />

    <style>
        :root {
            --primary: #0ea5e9;
            --accent: #7c3aed;
            --text: #0f172a;
            --muted: #64748b;
        }

        body {
            min-height: 100vh;
            background: linear-gradient(135deg, #0f172a 0%, #1e2937 50%, #312e81 100%);
            font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            color: white;
            padding: 2rem 1rem;
            overflow-y: auto;
            position: relative;
        }

            /* Animated background orbs */
            body::before {
                content: '';
                position: fixed;
                inset: 0;
                background: radial-gradient(circle at 20% 30%, rgba(14, 165, 233, 0.15) 0%, transparent 50%), radial-gradient(circle at 80% 70%, rgba(124, 58, 237, 0.15) 0%, transparent 50%), radial-gradient(circle at 40% 80%, rgba(14, 165, 233, 0.1) 0%, transparent 50%);
                animation: orbMove 35s ease infinite;
                z-index: -2;
                pointer-events: none;
            }

        @@keyframes orbMove {
            0%

        {
            transform: translate(0, 0) rotate(0deg);
        }

        50% {
            transform: translate(30px, -40px) rotate(8deg);
        }

        100% {
            transform: translate(0, 0) rotate(0deg);
        }

        }

        .register-card {
            background: rgba(255, 255, 255, 0.09);
            backdrop-filter: blur(24px);
            -webkit-backdrop-filter: blur(24px);
            border: 1px solid rgba(255, 255, 255, 0.18);
            border-radius: 2rem;
            box-shadow: 0 25px 70px rgba(0, 0, 0, 0.4);
            padding: 3rem 2.75rem;
            max-width: 500px;
            margin: 0 auto;
            transition: all 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
            position: relative;
            overflow: hidden;
        }

            .register-card::before {
                content: '';
                position: absolute;
                top: -50%;
                left: -50%;
                width: 200%;
                height: 200%;
                background: radial-gradient(circle, rgba(255,255,255,0.12) 0%, transparent 70%);
                opacity: 0;
                transition: opacity 0.6s;
                z-index: -1;
            }

            .register-card:hover {
                transform: translateY(-15px) scale(1.03);
                box-shadow: 0 35px 90px rgba(14, 165, 233, 0.35);
            }

                .register-card:hover::before {
                    opacity: 1;
                }

        .header-line {
            height: 5px;
            width: 90px;
            background: linear-gradient(90deg, var(--primary), var(--accent));
            border-radius: 999px;
            margin: 0 auto 1.8rem;
        }

        h2 {
            font-size: 2.6rem;
            font-weight: 800;
            text-align: center;
            background: linear-gradient(90deg, #67e8f9, #c4b5fd);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin-bottom: 0.5rem;
        }

        .subtitle {
            text-align: center;
            color: rgba(255,255,255,0.75);
            font-size: 1.1rem;
            margin-bottom: 2.2rem;
        }

        .form-label {
            font-weight: 600;
            color: rgba(255,255,255,0.9);
        }

        .form-control {
            background: rgba(255,255,255,0.08);
            border: 1px solid rgba(255,255,255,0.2);
            color: white;
            border-radius: 1.1rem;
            padding: 0.9rem 1.4rem;
            transition: all 0.3s ease;
        }

            .form-control:focus {
                background: rgba(255,255,255,0.12);
                border-color: var(--primary);
                box-shadow: 0 0 0 4px rgba(14, 165, 233, 0.25);
                color: white;
            }

            .form-control::placeholder {
                color: rgba(255,255,255,0.5);
            }

        .password-toggle {
            right: 1.4rem;
            top: 50%;
            transform: translateY(-50%);
            color: rgba(255,255,255,0.6);
            background: none;
            border: none;
            font-size: 1.25rem;
        }

        .strength-meter {
            height: 6px;
            background: rgba(255,255,255,0.15);
            border-radius: 999px;
            overflow: hidden;
            margin: 0.5rem 0;
        }

        .strength-fill {
            height: 100%;
            width: 0%;
            transition: width 0.4s ease, background 0.4s ease;
        }

        .btn-signup {
            background: linear-gradient(135deg, #0ea5e9, #7c3aed);
            border: none;
            font-weight: 700;
            font-size: 1.15rem;
            padding: 1.1rem;
            border-radius: 1.25rem;
            color: white;
            position: relative;
            overflow: hidden;
            transition: all 0.4s ease;
        }

            .btn-signup:hover {
                transform: translateY(-4px);
                box-shadow: 0 20px 40px rgba(124, 58, 237, 0.5);
            }

            .btn-signup::after {
                content: '';
                position: absolute;
                top: -50%;
                left: -100%;
                width: 50%;
                height: 200%;
                background: linear-gradient(120deg, transparent, rgba(255,255,255,0.4), transparent);
                transition: 0.7s;
            }

            .btn-signup:hover::after {
                left: 150%;
            }

        .login-text a {
            color: #67e8f9;
            font-weight: 600;
            text-decoration: none;
        }

            .login-text a:hover {
                text-decoration: underline;
            }

        @@media (max-width: 576px) {
            .register-card

        {
            padding: 2.2rem 1.6rem;
        }

        h2 {
            font-size: 2.2rem;
        }

        }
    </style>
</head>
<body>
    <div class="register-card">
        <div class="header-line"></div>
        <h2>Join EventsMS</h2>
        <p class="subtitle">Create your account and discover unforgettable events</p>

        <form asp-action="Register" method="post" class="needs-validation" novalidate id="registerForm">
            <div class="mb-3">
                <label asp-for="FullName" class="form-label">Full Name</label>
                <input asp-for="FullName" class="form-control" placeholder="Your full name" required autofocus />
                <span asp-validation-for="FullName" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label">Email Address</label>
                <input asp-for="Email" class="form-control" type="email" placeholder="you@example.com" required />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="PhoneNumber" class="form-label">Phone Number</label>
                <input asp-for="PhoneNumber" class="form-control" placeholder="01XXXXXXXXX" />
                <span asp-validation-for="PhoneNumber" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Address" class="form-label">Address / City</label>
                <input asp-for="Address" class="form-control" placeholder="Dhaka, Bangladesh" />
            </div>

            <div class="mb-3 position-relative">
                <label asp-for="Password" class="form-label">Password</label>
                <input asp-for="Password" class="form-control" type="password" id="password" minlength="8" required />
                <button type="button" class="password-toggle position-absolute" id="togglePassword">
                    <i class="bi bi-eye"></i>
                </button>
                <div class="strength-meter mt-2">
                    <div class="strength-fill" id="strengthFill"></div>
                </div>
                <div id="strengthText" class="small text-end" style="color:rgba(255,255,255,0.7);">Password strength</div>
            </div>

            <div class="mb-4">
                <label asp-for="ConfirmPassword" class="form-label">Confirm Password</label>
                <input asp-for="ConfirmPassword" class="form-control" type="password" id="confirmPassword" required />
                <div id="passwordMatchMessage" class="small mt-1"></div>
            </div>

            <div class="form-check mb-4">
                <input class="form-check-input" type="checkbox" id="termsCheck" required>
                <label class="form-check-label small" for="termsCheck" style="color:rgba(255,255,255,0.8);">
                    I agree to the <a href="#" class="text-decoration-none" style="color:#67e8f9;">Terms</a> and
                    <a href="#" class="text-decoration-none" style="color:#67e8f9;">Privacy Policy</a>
                </label>
            </div>

            <button type="submit" class="btn btn-signup w-100">
                <i class="bi bi-rocket-takeoff me-2"></i> Create My Account
            </button>

            <div class="text-center mt-4 login-text">
                Already have an account?
                <a asp-controller="Account" asp-action="Login">Sign in</a>
            </div>
        </form>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Password visibility toggle
        document.getElementById('togglePassword').addEventListener('click', function () {
            const pw = document.getElementById('password');
            const icon = this.querySelector('i');
            if (pw.type === 'password') {
                pw.type = 'text';
                icon.classList.replace('bi-eye', 'bi-eye-slash');
            } else {
                pw.type = 'password';
                icon.classList.replace('bi-eye-slash', 'bi-eye');
            }
        });

        // Password strength
        document.getElementById('password').addEventListener('input', function () {
            const val = this.value;
            const fill = document.getElementById('strengthFill');
            const text = document.getElementById('strengthText');
            let strength = 0;

            if (val.length >= 8) strength += 35;
            if (/[A-Z]/.test(val)) strength += 20;
            if (/\d/.test(val)) strength += 20;
            if (/[^A-Za-z0-9]/.test(val)) strength += 25;

            fill.style.width = strength + '%';

            if (strength < 50) {
                fill.style.background = '#f87171';
                text.textContent = 'Weak';
            } else if (strength < 80) {
                fill.style.background = '#fbbf24';
                text.textContent = 'Medium';
            } else {
                fill.style.background = '#4ade80';
                text.textContent = 'Strong';
            }
        });

        // Confirm password match
        const password = document.getElementById('password');
        const confirmPassword = document.getElementById('confirmPassword');
        const matchMsg = document.getElementById('passwordMatchMessage');

        function checkMatch() {
            if (confirmPassword.value === '') {
                matchMsg.textContent = '';
                return;
            }
            if (password.value === confirmPassword.value) {
                matchMsg.innerHTML = '<span style="color:#4ade80">✓ Passwords match perfectly</span>';
            } else {
                matchMsg.innerHTML = '<span style="color:#f87171">✗ Passwords do not match</span>';
            }
        }

        password.addEventListener('input', checkMatch);
        confirmPassword.addEventListener('input', checkMatch);
    </script>
</body>
</html>