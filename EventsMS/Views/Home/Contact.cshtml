@model EventsMS.Models.ContactViewModel

@{
    Layout = "_PublicLayout";
    ViewData["Title"] = "Contact Us";
}

<div class="container mt-5">
    <!-- Hero Header - More Dramatic -->
    <div class="text-center mb-5">
        <div class="hero-contact rounded-5 overflow-hidden position-relative mb-5">
            <div style="background: linear-gradient(135deg, #3b82f6 0%, #2563eb 50%, #1e40af 100%);
                        color: white;
                        padding: 6rem 2rem;
                        position: relative;">
                <div class="position-absolute top-0 start-0 w-100 h-100"
                     style="background: url('https://picsum.photos/id/1015/2000/1200') center/cover; opacity: 0.15;"></div>

                <div class="position-relative">
                    <h1 class="display-3 fw-bold mb-3">Get in Touch</h1>
                    <p class="lead fs-4 opacity-90 mb-0">
                        We'd love to hear from you. Drop us a message and we'll get back to you quickly.
                    </p>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-5">
        <!-- Contact Information -->
        <div class="col-lg-5">
            <div class="card border-0 shadow-xl h-100 rounded-4 overflow-hidden"
                 style="background: var(--bg-card);">
                <div class="card-body p-5">
                    <h4 class="fw-bold mb-4 text-primary">Contact Information</h4>

                    <div class="contact-item d-flex align-items-start mb-5">
                        <div class="icon-circle bg-primary bg-opacity-10 text-primary rounded-circle d-flex align-items-center justify-content-center me-4"
                             style="width: 52px; height: 52px;">
                            <i class="bi bi-envelope fs-4"></i>
                        </div>
                        <div>
                            <h6 class="fw-semibold mb-1">Email Us</h6>
                            <a href="mailto:info@eventsms.com" class="text-decoration-none fs-5">info@eventsms.com</a>
                        </div>
                    </div>

                    <div class="contact-item d-flex align-items-start mb-5">
                        <div class="icon-circle bg-primary bg-opacity-10 text-primary rounded-circle d-flex align-items-center justify-content-center me-4"
                             style="width: 52px; height: 52px;">
                            <i class="bi bi-telephone fs-4"></i>
                        </div>
                        <div>
                            <h6 class="fw-semibold mb-1">Call Us</h6>
                            <a href="tel:+8801712345678" class="text-decoration-none fs-5">+880 1712-345678</a>
                        </div>
                    </div>

                    <div class="contact-item d-flex align-items-start">
                        <div class="icon-circle bg-primary bg-opacity-10 text-primary rounded-circle d-flex align-items-center justify-content-center me-4"
                             style="width: 52px; height: 52px;">
                            <i class="bi bi-geo-alt fs-4"></i>
                        </div>
                        <div>
                            <h6 class="fw-semibold mb-1">Visit Us</h6>
                            <p class="text-muted mb-0 fs-6">
                                123 Gulshan Avenue, Block-A<br>
                                Dhaka 1212, Bangladesh
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Contact Form -->
        <div class="col-lg-7">
            <div class="card border-0 shadow-xl rounded-4 overflow-hidden"
                 style="background: var(--bg-card);">
                <div class="card-body p-5">
                    <h4 class="fw-bold mb-4 text-primary">Send us a Message</h4>

                    <form asp-controller="Home" asp-action="Contact" method="post">
                        @Html.AntiForgeryToken()

                        <div class="row g-4">
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Your Name</label>
                                <input asp-for="Name" class="form-control form-control-lg rounded-4"
                                       placeholder="Enter your full name" required />
                                <span asp-validation-for="Name" class="text-danger small mt-1"></span>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Your Email</label>
                                <input asp-for="Email" type="email" class="form-control form-control-lg rounded-4"
                                       placeholder="your@email.com" required />
                                <span asp-validation-for="Email" class="text-danger small mt-1"></span>
                            </div>
                        </div>

                        <div class="mt-4">
                            <label class="form-label fw-semibold">Your Message</label>
                            <textarea asp-for="Message" class="form-control form-control-lg rounded-4"
                                      rows="7" placeholder="Tell us how we can help you..." required></textarea>
                            <span asp-validation-for="Message" class="text-danger small mt-1"></span>
                        </div>

                        <div class="mt-5">
                            <button type="submit"
                                    class="btn btn-primary btn-lg w-100 rounded-4 py-3 fw-bold shadow-sm">
                                <i class="bi bi-send-fill me-2"></i> Send Message
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Google Map -->
    <div class="mt-5">
        <div class="card border-0 shadow-xl rounded-4 overflow-hidden">
            <div class="card-header bg-transparent border-0 py-4 px-5 d-flex justify-content-between align-items-center">
                <h5 class="mb-0 fw-bold">Our Location in Dhaka</h5>
                <span class="badge bg-primary">Gulshan</span>
            </div>
            <div class="ratio ratio-21x9">
                <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3651.8!2d90.4125!3d23.790!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3755c7a0f0f0f0f0%3A0x1234567890abcdef!2sGulshan%2C+Dhaka!5e0!3m2!1sen!2sbd!4v1700000000000"
                        width="100%" height="480" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .hero-contact {
            box-shadow: 0 25px 60px -15px rgba(59, 130, 246, 0.6);
        }

        .card {
            transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
        }

            .card:hover {
                transform: translateY(-12px) scale(1.02);
                box-shadow: 0 30px 70px -20px rgba(0, 0, 0, 0.2) !important;
            }

        .icon-circle {
            transition: all 0.3s ease;
        }

        .contact-item:hover .icon-circle {
            transform: scale(1.15);
            background-color: rgba(59, 130, 246, 0.2) !important;
        }

        .form-control {
            border: 2px solid var(--border-light);
            border-radius: 16px;
            padding: 14px 20px;
            font-size: 1.05rem;
            transition: all 0.3s ease;
        }

            .form-control:focus {
                border-color: var(--primary);
                box-shadow: 0 0 0 6px rgba(59, 130, 246, 0.15);
                outline: none;
            }

        [data-bs-theme="dark"] .form-control {
            background-color: #1e2937;
            border-color: #475569;
            color: #e2e8f0;
        }

        .btn-primary {
            background: linear-gradient(90deg, var(--primary), var(--primary-dark));
            border: none;
            font-size: 1.1rem;
            transition: all 0.4s ease;
        }

            .btn-primary:hover {
                transform: translateY(-4px);
                box-shadow: 0 15px 30px rgba(59, 130, 246, 0.5);
            }

        /* Extra polish */
        .card-header {
            background: var(--bg-card) !important;
        }
    </style>
}