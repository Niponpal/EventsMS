@model EventsMS.Models.ContactViewModel
@{
    Layout = "_PublicLayout";
    ViewData["Title"] = "Contact Us";
}

<div class="container py-5">
    <!-- Hero Section - More Impactful -->
    <div class="text-center mb-5">
        <div class="hero-contact position-relative rounded-5 overflow-hidden shadow-2xl">
            <div class="hero-bg d-flex align-items-center justify-content-center text-white"
                 style="min-height: 420px; background: linear-gradient(135deg, #1e3a8a 0%, #3b82f6 100%);">

                <!-- Background Overlay Image -->
                <div class="position-absolute inset-0"
                     style="background: url('https://picsum.photos/id/1015/2000/1200') center/cover; opacity: 0.18;"></div>

                <div class="position-relative text-center px-4">
                    <span class="badge bg-white text-primary px-4 py-2 rounded-pill mb-4 fs-6 fw-semibold">
                        We're Here For You
                    </span>
                    <h1 class="display-3 fw-bold mb-3">Get In Touch</h1>
                    <p class="lead fs-3 opacity-90 max-w-2xl mx-auto">
                        Have questions? Want to collaborate? Or just want to say hello?<br>
                        We'd love to hear from you.
                    </p>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-5">
        <!-- Contact Info Sidebar -->
        <div class="col-lg-5">
            <div class="sticky-top" style="top: 100px;">
                <div class="card border-0 shadow-xl rounded-4 overflow-hidden h-100">
                    <div class="card-body p-5">
                        <h4 class="fw-bold text-primary mb-5">Contact Information</h4>

                        <div class="contact-item d-flex gap-4 mb-5">
                            <div class="icon-wrapper bg-primary bg-opacity-10 text-primary rounded-3 d-flex align-items-center justify-content-center flex-shrink-0"
                                 style="width: 64px; height: 64px;">
                                <i class="bi bi-envelope-at fs-3"></i>
                            </div>
                            <div class="pt-1">
                                <h6 class="fw-semibold mb-2 fs-5">Email Us</h6>
                                <a href="mailto:info@eventsms.com" class="fs-5 text-decoration-none link-hover">
                                    info@eventsms.com
                                </a>
                            </div>
                        </div>

                        <div class="contact-item d-flex gap-4 mb-5">
                            <div class="icon-wrapper bg-primary bg-opacity-10 text-primary rounded-3 d-flex align-items-center justify-content-center flex-shrink-0"
                                 style="width: 64px; height: 64px;">
                                <i class="bi bi-telephone-outbound fs-3"></i>
                            </div>
                            <div class="pt-1">
                                <h6 class="fw-semibold mb-2 fs-5">Call or WhatsApp</h6>
                                <a href="tel:+8801712345678" class="fs-5 text-decoration-none link-hover">
                                    +880 1712-345678
                                </a>
                            </div>
                        </div>

                        <div class="contact-item d-flex gap-4">
                            <div class="icon-wrapper bg-primary bg-opacity-10 text-primary rounded-3 d-flex align-items-center justify-content-center flex-shrink-0"
                                 style="width: 64px; height: 64px;">
                                <i class="bi bi-geo-alt fs-3"></i>
                            </div>
                            <div class="pt-1">
                                <h6 class="fw-semibold mb-2 fs-5">Our Office</h6>
                                <p class="mb-0 text-muted fs-6">
                                    123 Gulshan Avenue, Block-A<br>
                                    Dhaka 1212, Bangladesh
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Contact Form -->
        <div class="col-lg-7">
            <div class="card border-0 shadow-xl rounded-4 overflow-hidden">
                <div class="card-body p-5 p-lg-6">
                    <h4 class="fw-bold text-primary mb-4">Send Us a Message</h4>
                    <p class="text-muted mb-5">Our team typically replies within 24 hours.</p>

                    <form asp-controller="Home" asp-action="Contact" method="post">
                        @Html.AntiForgeryToken()

                        <div class="row g-4">
                            <div class="col-md-6">
                                <label class="form-label fw-medium">Full Name</label>
                                <input asp-for="Name" class="form-control form-control-lg rounded-3"
                                       placeholder="John Doe" required />
                                <span asp-validation-for="Name" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-medium">Email Address</label>
                                <input asp-for="Email" type="email" class="form-control form-control-lg rounded-3"
                                       placeholder="you@example.com" required />
                                <span asp-validation-for="Email" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mt-4">
                            <label class="form-label fw-medium">Your Message</label>
                            <textarea asp-for="Message" rows="8"
                                      class="form-control form-control-lg rounded-3"
                                      placeholder="How can we help you today?"></textarea>
                            <span asp-validation-for="Message" class="text-danger"></span>
                        </div>

                        <div class="mt-5">
                            <button type="submit"
                                    class="btn btn-primary btn-lg w-100 py-3.5 rounded-3 fw-semibold shadow">
                                <i class="bi bi-send-fill me-2"></i>
                                Send Message
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Google Map Section -->
    <div class="mt-5">
        <div class="card border-0 shadow-xl rounded-4 overflow-hidden">
            <div class="px-5 py-4 d-flex justify-content-between align-items-center border-bottom">
                <h5 class="mb-0 fw-semibold">Our Location in Dhaka</h5>
                <span class="badge bg-primary px-3 py-2">Gulshan, Dhaka</span>
            </div>
            <div class="ratio ratio-21x9">
                <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3651.8!2d90.4125!3d23.790!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3755c7a0f0f0f0f0%3A0x1234567890abcdef!2sGulshan%2C+Dhaka!5e0!3m2!1sen!2sbd!4v1700000000000"
                        width="100%" height="450" style="border:0;" allowfullscreen="" loading="lazy"></iframe>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .hero-contact .hero-bg {
            position: relative;
        }

        .hero-contact {
            box-shadow: 0 30px 80px -20px rgba(59, 130, 246, 0.5);
        }

        .contact-item:hover .icon-wrapper {
            transform: scale(1.12) rotate(8deg);
            background-color: rgba(59, 130, 246, 0.25) !important;
        }

        .icon-wrapper {
            transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
        }

        .link-hover:hover {
            color: #3b82f6 !important;
            text-decoration: underline !important;
        }

        .card {
            transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.4s ease;
        }

            .card:hover {
                transform: translateY(-15px);
                box-shadow: 0 35px 80px -15px rgba(0, 0, 0, 0.18) !important;
            }

        .form-control {
            border: 2px solid #e2e8f0;
            padding: 16px 20px;
            font-size: 1.05rem;
            border-radius: 14px;
            transition: all 0.3s ease;
        }

            .form-control:focus {
                border-color: #3b82f6;
                box-shadow: 0 0 0 5px rgba(59, 130, 246, 0.15);
            }

        .btn-primary {
            background: linear-gradient(90deg, #3b82f6, #2563eb);
            border: none;
            font-size: 1.15rem;
        }

            .btn-primary:hover {
                transform: translateY(-3px);
                box-shadow: 0 15px 35px rgba(59, 130, 246, 0.4);
            }
    </style>
}