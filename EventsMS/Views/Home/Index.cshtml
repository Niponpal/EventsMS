@model IEnumerable<EventsMS.Models.Event>


<div class="container-fluid px-0 mt-5">
    <!-- Page Header -->
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-5 gap-4">
        <div>
            <h1 class="fw-bold mb-1" style="color: var(--text-primary);">All Events</h1>
            <p class="text-muted mb-0 fs-5">Discover and manage amazing events happening around you</p>
        </div>

        <a asp-action="CreateOrEdit"
           class="btn btn-primary rounded-pill px-5 py-3 shadow-sm d-flex align-items-center gap-2 fw-medium">
            <i class="bi bi-plus-lg"></i>
            Create New Event
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5 my-5">
            <i class="bi bi-calendar-x display-1 text-muted opacity-50"></i>
            <h3 class="fw-bold text-muted mt-4">No Events Found</h3>
            <p class="text-muted col-md-6 mx-auto">You haven't created any events yet.<br>Start by adding your first one!</p>
            <a asp-action="CreateOrEdit" class="btn btn-primary mt-4 rounded-pill px-5 py-3">
                <i class="bi bi-plus-circle me-2"></i>Add First Event
            </a>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var item in Model)
            {
                <div class="col-12 col-md-6 col-lg-4 col-xl-3">
                    <div class="event-card h-100 border-0 shadow-sm overflow-hidden">

                        <!-- Image with Gradient Overlay -->
                        <div class="position-relative overflow-hidden">
                            <img src="@item.ImageUrl"
                                 class="event-image w-100"
                                 style="height: 260px; object-fit: cover;"
                                 alt="@item.Name"
                                 loading="lazy" />

                            <!-- Gradient Overlay -->
                            <div class="position-absolute top-0 start-0 end-0 bottom-0 bg-gradient-overlay"></div>

                            <!-- Date Badge -->
                            <div class="position-absolute top-3 end-3">
                                <div class="badge bg-white text-dark shadow-sm px-3 py-2 fw-semibold rounded-3">
                                    @item.StartDate.ToString("dd MMM")
                                </div>
                            </div>
                        </div>

                        <div class="card-body p-4 d-flex flex-column">
                            <!-- Category -->
                            <span class="dept-badge mb-3 d-inline-block">
                                @item.Category?.Name
                            </span>

                            <!-- Event Name -->
                            <h5 class="card-title fw-semibold mb-3 line-clamp-2">
                                @item.Name
                            </h5>

                            <!-- Date Range -->
                            <div class="d-flex align-items-center gap-2 mb-3 text-muted small">
                                <i class="bi bi-calendar3 text-primary"></i>
                                <span>
                                    @item.StartDate.ToString("dd MMM yyyy") — @item.EndDate.ToString("dd MMM yyyy")
                                </span>
                            </div>

                            <!-- Meals & Fee -->
                            <div class="d-flex flex-wrap gap-2 mb-4">
                                <span class="badge rounded-pill px-3 py-1.5 bg-light border text-primary fw-medium">
                                    Meals: @item.MealsOffered
                                </span>

                                @if (item.IsFree)
                                {
                                    <span class="badge rounded-pill px-3 py-1.5 bg-success-subtle text-success fw-medium">
                                        <i class="bi bi-check2-circle me-1"></i> Free Event
                                    </span>
                                }
                                else
                                {
                                    <span class="badge rounded-pill px-3 py-1.5 bg-warning-subtle text-warning fw-medium">
                                        Fee: @item.RegistrationFee ৳
                                    </span>
                                }
                        </div>

                        <!-- Description -->
                        <p class="card-text flex-grow-1 text-muted small line-clamp-3 mb-4">
                            @(item.Description?.Length > 135
                                                    ? item.Description.Substring(0, 135) + "..."
                                                    : item.Description ?? "No description provided.")
                    </p>

                            <!-- Action Button -->
                            <div class="mt-auto">
                                <a asp-action="Apply" asp-route-id="@item.Id"
                                   class="btn btn-primary w-100 rounded-pill py-3 fw-medium shadow-sm">
                                    <i class="bi bi-check-circle me-2"></i> Apply Now
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
                }
        </div>
    }
</div>

<style>
    :root {
        --radius: 18px;
    }

    .event-card {
        border-radius: var(--radius);
        background: var(--card-bg, #ffffff);
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        border: 1px solid rgba(0,0,0,0.06);
    }

        .event-card:hover {
            transform: translateY(-12px);
            box-shadow: 0 20px 45px rgba(0, 0, 0, 0.13);
        }

    .event-image {
        transition: transform 0.7s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .event-card:hover .event-image {
        transform: scale(1.08);
    }

    .bg-gradient-overlay {
        background: linear-gradient(to top, rgba(0,0,0,0.65), rgba(0,0,0,0.15));
    }

    .dept-badge {
        font-size: 0.82rem;
        padding: 6px 16px;
        background: rgba(30, 64, 175, 0.08);
        color: #1e40af;
        border: 1px solid rgba(30, 64, 175, 0.25);
        border-radius: 50px;
        font-weight: 500;
    }

    .line-clamp-2, .line-clamp-3 {
        display: -webkit-box;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .line-clamp-2 {
        -webkit-line-clamp: 2;
    }

    .line-clamp-3 {
        -webkit-line-clamp: 3;
    }

    /* Dark Mode */
    [data-bs-theme="dark"] .event-card {
        background: var(--card-bg, #1f2937);
        border-color: rgba(255,255,255,0.08);
    }

    [data-bs-theme="dark"] .bg-gradient-overlay {
        background: linear-gradient(to top, rgba(0,0,0,0.85), rgba(0,0,0,0.25));
    }

    [data-bs-theme="dark"] .dept-badge {
        background: rgba(147, 197, 253, 0.12);
        color: #93c5fd;
        border-color: rgba(147, 197, 253, 0.3);
    }
</style>