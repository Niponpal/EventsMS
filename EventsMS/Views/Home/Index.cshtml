@model IEnumerable<EventsMS.Models.Event>
@{
    Layout = null;
    ViewData["Title"] = "All Events";
}

<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>All Events - EventsMS</title>

    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700;14..32,800&display=swap" rel="stylesheet">

    <!-- Bootstrap + Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />

    <style>
        :root {
            --primary: #3b82f6;
            --primary-dark: #2563eb;
            --primary-light: #60a5fa;
            --bg-body: #f8fafc;
            --bg-card: #ffffff;
            --text-primary: #0f172a;
            --text-secondary: #475569;
            --border-light: #e2e8f0;
        }

        [data-bs-theme="dark"] {
            --bg-body: #0f172a;
            --bg-card: #1e293b;
            --text-primary: #e2e8f0;
            --text-secondary: #94a3b8;
            --border-light: #334155;
        }

        * {
            transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);
        }

        body {
            background: var(--bg-body);
            font-family: 'Inter', system-ui, -apple-system, sans-serif;
            color: var(--text-primary);
            overflow-x: hidden;
        }

            /* Subtle animated body background */
            body::before {
                content: '';
                position: fixed;
                inset: 0;
                background: linear-gradient(135deg, rgba(59,130,246,0.03) 0%, rgba(147,51,234,0.02) 50%, rgba(59,130,246,0.03) 100%);
                background-size: 400% 400%;
                animation: subtleGradient 25s ease infinite;
                z-index: -1;
                pointer-events: none;
            }

        @@keyframes subtleGradient {
            0%

        {
            background-position: 0% 50%;
        }

        50% {
            background-position: 100% 50%;
        }

        100% {
            background-position: 0% 50%;
        }

        }

        /* Hero */
        .hero {
            position: relative;
            background: linear-gradient(135deg, rgba(59,130,246,0.08) 0%, rgba(147,51,234,0.04) 100%);
            border-radius: 2.5rem;
            padding: 5rem 2rem;
            margin-bottom: 3.5rem;
            overflow: hidden;
            text-align: center;
        }

            .hero::before,
            .hero::after {
                content: '';
                position: absolute;
                border-radius: 50%;
                background: radial-gradient(circle, rgba(59,130,246,0.25) 0%, transparent 70%);
                filter: blur(40px);
                animation: floatOrb 30s ease-in-out infinite;
                z-index: 0;
            }

            .hero::before {
                width: 500px;
                height: 500px;
                top: -150px;
                left: -100px;
            }

            .hero::after {
                width: 400px;
                height: 400px;
                bottom: -120px;
                right: -80px;
                background: radial-gradient(circle, rgba(147,51,234,0.18) 0%, transparent 70%);
                animation-delay: 12s;
            }

        @@keyframes floatOrb {
            0%, 100%

        {
            transform: translate(0, 0) rotate(0deg);
        }

        50% {
            transform: translate(60px, 40px) rotate(15deg);
        }

        }

        .hero h1 {
            font-size: 3.4rem;
            font-weight: 800;
            background: linear-gradient(90deg, var(--primary), var(--primary-light));
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            z-index: 2;
            position: relative;
        }

        .hero p {
            font-size: 1.3rem;
            color: var(--text-secondary);
            max-width: 680px;
            margin: 0 auto;
            position: relative;
            z-index: 2;
        }

        /* Navbar */
        .navbar {
            background: rgba(255, 255, 255, 0.96);
            backdrop-filter: blur(20px);
            border-bottom: 1px solid var(--border-light);
            padding: 1rem 0;
            box-shadow: 0 4px 20px rgba(0,0,0,0.06);
        }

        [data-bs-theme="dark"] .navbar {
            background: rgba(15, 23, 42, 0.96);
        }

        /* Event Cards */
        .event-card {
            background: var(--bg-card);
            border-radius: 1.75rem;
            border: 1px solid var(--border-light);
            overflow: hidden;
            height: 100%;
            display: flex;
            flex-direction: column;
            box-shadow: 0 10px 30px -10px rgba(0,0,0,0.08);
            opacity: 0;
            transform: translateY(50px);
            transition: all 0.7s cubic-bezier(0.25, 0.46, 0.45, 0.94);
        }

            .event-card.visible {
                opacity: 1;
                transform: translateY(0);
            }

            .event-card:hover {
                transform: translateY(-12px) scale(1.02);
                box-shadow: 0 25px 50px -12px rgba(59,130,246,0.25);
                border-color: var(--primary-light);
            }

        .card-img-top {
            height: 240px;
            object-fit: cover;
            transition: transform 0.6s ease;
        }

        .event-card:hover .card-img-top {
            transform: scale(1.1);
        }

        /* Buttons */
        .btn-apply, .btn-details {
            border-radius: 9999px;
            padding: 0.75rem 1.5rem;
            font-weight: 600;
        }

        .btn-details {
            background-color: transparent;
            border: 2px solid var(--primary);
            color: var(--primary);
        }

            .btn-details:hover {
                background-color: var(--primary);
                color: white;
                transform: translateY(-2px);
            }

        .btn-apply {
            position: relative;
            overflow: hidden;
        }

            .btn-apply::after {
                content: '';
                position: absolute;
                top: -50%;
                left: -50%;
                width: 40%;
                height: 400%;
                background: linear-gradient(120deg, transparent, rgba(255,255,255,0.4), transparent);
                transform: skewX(-25deg);
                animation: shimmer 4s infinite;
            }

        @@keyframes shimmer {
            100%

        {
            transform: translateX(400%);
        }

        }

        /* Footer */
        .footer {
            background: var(--bg-card);
            border-top: 1px solid var(--border-light);
            padding: 4.5rem 0 2.5rem;
            margin-top: 7rem;
        }

        .footer-section {
            opacity: 0;
            transform: translateY(40px);
            transition: all 0.9s cubic-bezier(0.25, 0.46, 0.45, 0.94);
        }

            .footer-section.visible {
                opacity: 1;
                transform: translateY(0);
            }

        .social-links a {
            width: 46px;
            height: 46px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            background: var(--bg-body);
            color: var(--text-secondary);
            border-radius: 50%;
            font-size: 1.25rem;
        }

            .social-links a:hover {
                background: var(--primary);
                color: white;
                transform: translateY(-4px) scale(1.1);
            }
    </style>
</head>
<body>

    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg sticky-top">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center gap-2" href="#">
                <i class="bi bi-calendar-event-fill fs-2"></i>
                <span>EventsMS</span>
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav mx-auto gap-1">
                    <li class="nav-item"><a asp-action="Index" class="nav-link active">All Events</a></li>
                    <li class="nav-item"><a asp-controller="Home" asp-action="index" class="nav-link">My Events</a></li>
                    <li class="nav-item"><a asp-controller="Home" asp-action="index" class="nav-link">Upcoming</a></li>
                </ul>
                <div class="d-flex align-items-center gap-3">
                    <button id="themeToggle" class="btn btn-outline-secondary rounded-circle p-2" style="width: 42px; height: 42px;">
                        <i class="bi bi-moon-stars-fill"></i>
                    </button>
                    <div class="dropdown">
                        <a class="d-flex align-items-center text-decoration-none dropdown-toggle" href="#" data-bs-toggle="dropdown">
                            <i class="bi bi-person-circle fs-3 text-secondary"></i>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end shadow">
                            <li><a asp-action="Index" asp-controller="Dashboard" class="dropdown-item"><i class="bi bi-person me-2"></i>Profile</a></li>
                            <li><a class="dropdown-item" href="#"><i class="bi bi-gear me-2"></i>Settings</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item text-danger" href="#">Logout</a></li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </nav>

    <div class="container mt-5">
        <!-- Hero -->
        <div class="hero">
            <h1>Discover Amazing Events</h1>
            <p>Explore, connect, and create unforgettable experiences with EventsMS</p>
        </div>

        <!-- Filter Bar -->
        <div class="filter-bar bg-white border rounded-4 p-4 shadow-sm mb-5">
            <div class="row g-3 align-items-end">
                <div class="col-md-5">
                    <label class="form-label fw-semibold">Search events</label>
                    <input type="text" id="searchInput" class="form-control" placeholder="Event name, category..." style="border-radius: 9999px; padding: 0.75rem 1.25rem;">
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-semibold">Category</label>
                    <select id="categoryFilter" class="form-select" style="border-radius: 9999px; padding: 0.75rem 1.25rem;">
                        <option value="">All Categories</option>
                        @foreach (var cat in Model.Select(e => e.Category?.Name).Where(c => !string.IsNullOrEmpty(c)).Distinct())
                        {
                            <option value="@cat">@cat</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label fw-semibold">Price</label>
                    <select id="priceFilter" class="form-select" style="border-radius: 9999px; padding: 0.75rem 1.25rem;">
                        <option value="">All</option>
                        <option value="free">Free</option>
                        <option value="paid">Paid</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <button id="resetFilters" class="btn btn-outline-secondary w-100 rounded-pill py-3">Reset Filters</button>
                </div>
            </div>
        </div>

        @if (!Model.Any())
        {
            <div class="text-center py-5">
                <i class="bi bi-calendar-x display-1 text-muted"></i>
                <h3 class="mt-4 fw-bold">No Events Found</h3>
                <p class="text-muted">Start by creating your first event.</p>
                <a asp-action="CreateOrEdit" class="btn btn-primary btn-lg rounded-pill px-5 py-3 mt-3">
                    <i class="bi bi-plus-circle me-2"></i>Add First Event
                </a>
            </div>
        }
        else
        {
            <div class="row g-4" id="eventsContainer">
                @foreach (var item in Model)
                {
                    <div class="col-12 col-md-6 col-lg-4 event-item"
                         data-name="@item.Name.ToLower()"
                         data-category="@(item.Category?.Name?.ToLower() ?? "")"
                         data-price="@(item.IsFree ? "free" : "paid")">
                        <div class="event-card">
                            <div class="position-relative">
                                <img src="@item.ImageUrl" class="card-img-top" alt="@item.Name" loading="lazy" />
                                <div class="date-badge position-absolute top-0 end-0 m-3 bg-dark bg-opacity-75 text-white px-3 py-1 rounded-pill small fw-semibold">
                                    @item.StartDate.ToString("dd MMM")
                                </div>
                            </div>
                            <div class="p-4 d-flex flex-column flex-grow-1">
                                <span class="category-badge align-self-start mb-3">@(item.Category?.Name ?? "General")</span>
                                <h5 class="event-title mb-3">@item.Name</h5>
                                <div class="event-meta mb-3 small text-muted">
                                    <i class="bi bi-calendar3 me-1"></i>
                                    @item.StartDate.ToString("dd MMM yyyy") – @item.EndDate.ToString("dd MMM yyyy")
                                </div>
                                <div class="d-flex flex-wrap gap-2 mb-4">
                                    <span class="badge bg-light border text-dark">Meals: @item.MealsOffered</span>
                                    @if (item.IsFree)
                                    {
                                        <span class="badge bg-success">Free</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning text-dark">৳ @item.RegistrationFee</span>
                                    }
                                </div>
                                <p class="flex-grow-1 text-muted small">
                                    @(item.Description?.Length > 130 ? item.Description.Substring(0, 130) + "..." : item.Description ?? "No description available.")
                                </p>

                                <!-- Action Buttons -->
                                <div class="d-flex gap-2 mt-auto">
                                    <!-- Details Button -->
                                    <a asp-controller="Home" asp-action="Details" asp-route-id="@item.Id"
                                       class="btn btn-details flex-grow-1 text-center">
                                        <i class="bi bi-info-circle me-2"></i>Details
                                    </a>
                                    <!-- Apply Button -->
                                    <a asp-controller="Studentregistration"
                                       asp-action="CreateOrEdit"
                                       asp-route-eventId="@item.Id"
                                       class="btn btn-primary btn-apply flex-grow-1 text-center">
                                        <i class="bi bi-check-circle me-2"></i>Apply Now
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>

    <!-- Footer -->
    <footer class="footer">
        <div class="container">
            <div class="row gy-5">
                <div class="col-lg-5 footer-section">
                    <div class="d-flex align-items-center gap-2 mb-3">
                        <i class="bi bi-calendar-event-fill fs-2 text-primary"></i>
                        <h4 class="mb-0 fw-bold">EventsMS</h4>
                    </div>
                    <p class="text-muted">Connecting people through meaningful events and unforgettable experiences.</p>
                    <div class="social-links mt-4">
                        <a href="#" aria-label="Facebook"><i class="bi bi-facebook"></i></a>
                        <a href="#" aria-label="Twitter"><i class="bi bi-twitter-x"></i></a>
                        <a href="#" aria-label="Instagram"><i class="bi bi-instagram"></i></a>
                        <a href="#" aria-label="LinkedIn"><i class="bi bi-linkedin"></i></a>
                    </div>
                </div>
                <div class="col-lg-2 col-md-6 footer-section">
                    <h5>Platform</h5>
                    <a href="#" class="footer-link d-block mb-2 text-decoration-none">Browse Events</a>
                    <a href="#" class="footer-link d-block mb-2 text-decoration-none">Create Event</a>
                    <a href="#" class="footer-link d-block mb-2 text-decoration-none">Upcoming Events</a>
                </div>
                <div class="col-lg-2 col-md-6 footer-section">
                    <h5>Company</h5>
                    <a href="#" class="footer-link d-block mb-2 text-decoration-none">About Us</a>
                    <a href="#" class="footer-link d-block mb-2 text-decoration-none">Careers</a>
                    <a href="#" class="footer-link d-block mb-2 text-decoration-none">Blog</a>
                    <a href="#" class="footer-link d-block mb-2 text-decoration-none">Contact</a>
                </div>
                <div class="col-lg-3 footer-section">
                    <h5>Support</h5>
                    <a href="#" class="footer-link d-block mb-2 text-decoration-none">Help Center</a>
                    <a href="#" class="footer-link d-block mb-2 text-decoration-none">Community Guidelines</a>
                    <a href="#" class="footer-link d-block mb-2 text-decoration-none">Terms of Service</a>
                    <a href="#" class="footer-link d-block mb-2 text-decoration-none">Privacy Policy</a>
                </div>
            </div>
            <hr class="my-5">
            <div class="text-center text-muted small">
                &copy; @DateTime.Now.Year EventsMS. All rights reserved.
                Made with <i class="bi bi-heart-fill text-danger"></i> for the community.
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Dark Mode
        const toggle = document.getElementById('themeToggle');
        const html = document.documentElement;
        let currentTheme = localStorage.getItem('theme') || 'light';
        html.setAttribute('data-bs-theme', currentTheme);

        function updateIcon() {
            const icon = toggle.querySelector('i');
            icon.classList.toggle('bi-moon-stars-fill', currentTheme === 'dark');
            icon.classList.toggle('bi-sun-fill', currentTheme === 'light');
        }
        updateIcon();

        toggle.addEventListener('click', () => {
            currentTheme = currentTheme === 'light' ? 'dark' : 'light';
            html.setAttribute('data-bs-theme', currentTheme);
            localStorage.setItem('theme', currentTheme);
            updateIcon();
        });

        // Animations
        function animateElements() {
            const cards = document.querySelectorAll('.event-card');
            const footerSections = document.querySelectorAll('.footer-section');

            const observer = new IntersectionObserver((entries) => {
                entries.forEach((entry, idx) => {
                    if (entry.isIntersecting) {
                        setTimeout(() => {
                            entry.target.classList.add('visible');
                        }, idx * 60);
                    }
                });
            }, { threshold: 0.2 });

            cards.forEach(card => observer.observe(card));
            footerSections.forEach(section => observer.observe(section));
        }

        // Filter
        const searchInput = document.getElementById('searchInput');
        const categoryFilter = document.getElementById('categoryFilter');
        const priceFilter = document.getElementById('priceFilter');
        const resetBtn = document.getElementById('resetFilters');
        const eventItems = document.querySelectorAll('.event-item');

        function filterEvents() {
            const searchTerm = searchInput.value.toLowerCase().trim();
            const category = categoryFilter.value.toLowerCase();
            const price = priceFilter.value;

            eventItems.forEach(item => {
                const nameMatch = item.getAttribute('data-name').includes(searchTerm);
                const catMatch = !category || item.getAttribute('data-category') === category;
                const priceMatch = !price || item.getAttribute('data-price') === price;
                item.style.display = (nameMatch && catMatch && priceMatch) ? '' : 'none';
            });
        }

        searchInput.addEventListener('input', filterEvents);
        categoryFilter.addEventListener('change', filterEvents);
        priceFilter.addEventListener('change', filterEvents);

        resetBtn.addEventListener('click', () => {
            searchInput.value = '';
            categoryFilter.value = '';
            priceFilter.value = '';
            filterEvents();
        });

        window.addEventListener('load', () => {
            animateElements();
        });
    </script>
</body>
</html>