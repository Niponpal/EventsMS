@model IEnumerable<EventsMS.Models.Event>

@{
    Layout = "_PublicLayout";   // ← This is the most important line
    ViewData["Title"] = "All Events";
}

<div class="container mt-5">
    <!-- Hero Section -->
    <div class="hero mb-5 text-center">
        <h1>Discover Amazing Events</h1>
        <p class="lead">Explore, connect, and create unforgettable experiences with EventsMS</p>
    </div>

    <!-- Filter Bar -->
    <div class="filter-bar bg-white border rounded-4 p-4 shadow-sm mb-5">
        <div class="row g-3 align-items-end">
            <div class="col-md-5">
                <label class="form-label fw-semibold">Search events</label>
                <input type="text" id="searchInput" class="form-control"
                       placeholder="Event name, category..."
                       style="border-radius: 9999px; padding: 0.75rem 1.25rem;">
            </div>
            <div class="col-md-3">
                <label class="form-label fw-semibold">Category</label>
                <select id="categoryFilter" class="form-select" style="border-radius: 9999px; padding: 0.75rem 1.25rem;">
                    <option value="">All Categories</option>
                    @foreach (var cat in Model.Select(e => e.Category?.Name).Where(c => !string.IsNullOrEmpty(c)).Distinct())
                    {
                        <option value="@cat">@cat</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label fw-semibold">Price</label>
                <select id="priceFilter" class="form-select" style="border-radius: 9999px; padding: 0.75rem 1.25rem;">
                    <option value="">All</option>
                    <option value="free">Free</option>
                    <option value="paid">Paid</option>
                </select>
            </div>
            <div class="col-md-2">
                <button id="resetFilters" class="btn btn-outline-secondary w-100 rounded-pill py-3">Reset Filters</button>
            </div>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-calendar-x display-1 text-muted"></i>
            <h3 class="mt-4 fw-bold">No Events Found</h3>
            <p class="text-muted">Start by creating your first event.</p>
            <a asp-action="CreateOrEdit" class="btn btn-primary btn-lg rounded-pill px-5 py-3 mt-3">
                <i class="bi bi-plus-circle me-2"></i>Add First Event
            </a>
        </div>
    }
    else
    {
        <div class="row g-4" id="eventsContainer">
            @foreach (var item in Model)
            {
                <div class="col-12 col-md-6 col-lg-4 event-item"
                     data-name="@item.Name.ToLower()"
                     data-category="@(item.Category?.Name?.ToLower() ?? "")"
                     data-price="@(item.IsFree ? "free" : "paid")">

                    <div class="event-card">
                        <div class="position-relative">
                            <img src="@item.ImageUrl" class="card-img-top" alt="@item.Name" loading="lazy" />
                            <div class="date-badge position-absolute top-0 end-0 m-3 bg-dark bg-opacity-75 text-white px-3 py-1 rounded-pill small fw-semibold">
                                @item.StartDate.ToString("dd MMM")
                            </div>
                        </div>
                        <div class="p-4 d-flex flex-column flex-grow-1">
                            <span class="category-badge align-self-start mb-3">@(item.Category?.Name ?? "General")</span>
                            <h5 class="event-title mb-3">@item.Name</h5>
                            <div class="event-meta mb-3 small text-muted">
                                <i class="bi bi-calendar3 me-1"></i>
                                @item.StartDate.ToString("dd MMM yyyy") – @item.EndDate.ToString("dd MMM yyyy")
                            </div>
                            <div class="d-flex flex-wrap gap-2 mb-4">
                                <span class="badge bg-light border text-dark">Meals: @item.MealsOffered</span>
                                @if (item.IsFree)
                                {
                                    <span class="badge bg-success">Free</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark">৳ @item.RegistrationFee</span>
                                }
                            </div>
                            <p class="flex-grow-1 text-muted small">
                                @(item.Description?.Length > 130 ? item.Description.Substring(0, 130) + "..." : item.Description ?? "No description available.")
                            </p>
                            <div class="d-flex gap-2 mt-auto">
                                <a asp-controller="Home" asp-action="Details" asp-route-id="@item.Id"
                                   class="btn btn-details flex-grow-1 text-center">
                                    <i class="bi bi-info-circle me-2"></i>Details
                                </a>
                               @*  <a asp-controller="Studentregistration" asp-action="CreateOrEdit" asp-route-eventId="@item.Id"
                                   class="btn btn-primary btn-apply flex-grow-1 text-center">
                                    <i class="bi bi-check-circle me-2"></i>Apply Now
                                </a>  *@

                                <a asp-controller="Studentregistration" asp-action="CreateOrEdit"
                                   asp-route-id="0" asp-route-eventId="@item.Id"
                                   class="btn btn-primary btn-apply flex-grow-1 text-center">
                                    <i class="bi bi-check-circle me-2"></i>Apply Now
                                </a>

          
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@section Styles {
    <style>
        .hero {
            background: linear-gradient(135deg, rgba(59,130,246,0.08) 0%, rgba(147,51,234,0.04) 100%);
            border-radius: 2.5rem;
            padding: 5rem 2rem;
        }

            .hero h1 {
                font-size: 3.4rem;
                font-weight: 800;
                background: linear-gradient(90deg, #3b82f6, #60a5fa);
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
            }

        .event-card {
            background: var(--bg-card);
            border-radius: 1.75rem;
            border: 1px solid var(--border-light);
            overflow: hidden;
            height: 100%;
            display: flex;
            flex-direction: column;
            box-shadow: 0 10px 30px -10px rgba(0,0,0,0.08);
            transition: all 0.4s ease;
        }

            .event-card:hover {
                transform: translateY(-12px) scale(1.02);
                box-shadow: 0 25px 50px -12px rgba(59,130,246,0.25);
            }

        .card-img-top {
            height: 240px;
            object-fit: cover;
            transition: transform 0.6s ease;
        }

        .event-card:hover .card-img-top {
            transform: scale(1.1);
        }

        .btn-apply, .btn-details {
            border-radius: 9999px;
            padding: 0.75rem 1.5rem;
            font-weight: 600;
        }

        .btn-details {
            background: transparent;
            border: 2px solid var(--primary);
            color: var(--primary);
        }

            .btn-details:hover {
                background: var(--primary);
                color: white;
            }
    </style>
}

@section Scripts {
    <script>
        const searchInput = document.getElementById('searchInput');
        const categoryFilter = document.getElementById('categoryFilter');
        const priceFilter = document.getElementById('priceFilter');
        const resetBtn = document.getElementById('resetFilters');
        const eventItems = document.querySelectorAll('.event-item');

        function filterEvents() {
            const searchTerm = searchInput.value.toLowerCase().trim();
            const category = categoryFilter.value.toLowerCase();
            const price = priceFilter.value;

            eventItems.forEach(item => {
                const nameMatch = item.getAttribute('data-name').includes(searchTerm);
                const catMatch = !category || item.getAttribute('data-category') === category;
                const priceMatch = !price || item.getAttribute('data-price') === price;

                item.style.display = (nameMatch && catMatch && priceMatch) ? '' : 'none';
            });
        }

        searchInput.addEventListener('input', filterEvents);
        categoryFilter.addEventListener('change', filterEvents);
        priceFilter.addEventListener('change', filterEvents);

        resetBtn.addEventListener('click', () => {
            searchInput.value = '';
            categoryFilter.value = '';
            priceFilter.value = '';
            filterEvents();
        });
    </script>
}
