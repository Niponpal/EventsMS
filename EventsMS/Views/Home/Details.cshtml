            border-radius: 1.25rem;
            padding: 1.5rem;
            border: 1px solid var(--border-light);
            transition: all 0.25s;
            box-shadow: var(--shadow-sm);
        }

            .info-card:hover {
                transform: translateY(-2px);
                box-shadow: var(--shadow-md);
                border-color: var(--primary-light);
            }

        .detail-label {
            font-size: 0.8rem;
            font-weight: 600;
            color: var(--text-secondary);
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .detail-value {
            font-size: 1.15rem;
            font-weight: 600;
            color: var(--text-primary);
            margin-top: 0.25rem;
        }

        /* Badges */
        .badge-custom {
            padding: 0.5rem 1.1rem;
            border-radius: 9999px;
            font-weight: 600;
            font-size: 0.9rem;
            backdrop-filter: blur(4px);
        }

        /* Buttons */
        .back-btn {
            transition: all 0.2s ease;
            font-weight: 500;
            padding: 0.5rem 1rem;
            border-radius: 2rem;
        }

            .back-btn:hover {
                transform: translateX(-4px);
                background: rgba(59, 130, 246, 0.1);
            }

        .apply-btn {
            padding: 1rem 2rem;
            font-size: 1.1rem;
            font-weight: 700;
            border-radius: 9999px;
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            border: none;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            box-shadow: 0 10px 25px -5px rgba(59, 130, 246, 0.4);
        }

            .apply-btn:hover:not(:disabled) {
                transform: translateY(-2px);
                box-shadow: 0 20px 30px -10px rgba(59, 130, 246, 0.5);
                background: linear-gradient(135deg, var(--primary-dark), var(--primary));
            }

            .apply-btn:disabled {
                opacity: 0.6;
                cursor: not-allowed;
                transform: none;
            }

        /* Countdown Timer */
        .countdown-timer {
            background: linear-gradient(135deg, rgba(59,130,246,0.1), rgba(37,99,235,0.05));
            border-radius: 1rem;
            padding: 0.75rem;
            text-align: center;
            font-weight: 600;
            border: 1px solid rgba(59,130,246,0.2);
        }

        .countdown-number {
            font-size: 1.5rem;
            font-weight: 800;
            color: var(--primary);
        }

        /* Share Dropdown */
        .share-dropdown .dropdown-menu {
            background: var(--bg-card);
            border-color: var(--border-light);
            box-shadow: var(--shadow-md);
            border-radius: 1rem;
            padding: 0.5rem;
        }

        .share-dropdown .dropdown-item {
            border-radius: 0.75rem;
            padding: 0.5rem 1rem;
            transition: all 0.2s;
        }

            .share-dropdown .dropdown-item:hover {
                background: var(--primary);
                color: white;
            }

        /* Footer */
        .footer-modern {
            background: var(--bg-card);
            border-top: 1px solid var(--border-light);
            padding: 3rem 0;
            margin-top: 4rem;
        }

        /* Responsive */
        @@media (max-width: 992px) {
            .hero-image {
                height: 380px;
            }

            .event-header {
                margin-top: 1.5rem;
            }
        }

        @@media (max-width: 768px) {
            .hero-image {
                height: 280px;
            }
        }
    </style>
</head>
<body>
    <!-- Modern Navbar -->
    <nav class="navbar-modern sticky-top">
        <div class="container">
            <a asp-action="Index" class="navbar-brand text-decoration-none">
                <i class="bi bi-calendar-event-fill me-2"></i>EventsMS
