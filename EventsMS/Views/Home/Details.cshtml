@model EventsMS.Models.Event

@{
    Layout = null;
    ViewData["Title"] = Model?.Name ?? "Event Details";
}

<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@Model.Name - EventsMS</title>

    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700;14..32,800&display=swap" rel="stylesheet">
    <!-- Bootstrap + Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />

    <style>
        :root {
            --primary: #3b82f6;
            --primary-dark: #2563eb;
            --bg-body: #f8fafc;
            --bg-card: #ffffff;
            --text-primary: #0f172a;
            --text-secondary: #475569;
            --border-light: #e2e8f0;
        }

        [data-bs-theme="dark"] {
            --bg-body: #0f172a;
            --bg-card: #1e293b;
            --text-primary: #e2e8f0;
            --text-secondary: #94a3b8;
            --border-light: #334155;
        }

        body {
            background: var(--bg-body);
            font-family: 'Inter', system-ui, -apple-system, sans-serif;
            color: var(--text-primary);
        }

        .hero-image {
            height: 520px;
            object-fit: cover;
            border-radius: 1.5rem;
            box-shadow: 0 20px 40px -15px rgba(0, 0, 0, 0.15);
        }

        .event-header {
            background: var(--bg-card);
            border-radius: 1.75rem;
            padding: 2.5rem;
            box-shadow: 0 10px 30px -10px rgba(0,0,0,0.08);
            border: 1px solid var(--border-light);
        }

        .info-card {
            background: var(--bg-card);
            border-radius: 1.25rem;
            padding: 1.75rem;
            border: 1px solid var(--border-light);
        }

        .detail-label {
            font-size: 0.9rem;
            font-weight: 600;
            color: var(--text-secondary);
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .detail-value {
            font-size: 1.15rem;
            font-weight: 500;
            color: var(--text-primary);
        }

        .badge-custom {
            padding: 0.5rem 1.1rem;
            border-radius: 9999px;
            font-weight: 600;
            font-size: 0.95rem;
        }

        .back-btn {
            transition: all 0.3s ease;
        }

            .back-btn:hover {
                transform: translateX(-5px);
            }

        .apply-btn {
            padding: 1rem 2.5rem;
            font-size: 1.1rem;
            font-weight: 700;
            border-radius: 9999px;
            box-shadow: 0 10px 25px -5px rgba(59, 130, 246, 0.4);
        }
    </style>
</head>
<body>
    <div class="container py-5">

        <!-- Back Button -->
        <div class="mb-4">
            <a asp-action="Index" class="btn btn-link text-decoration-none back-btn">
                <i class="bi bi-arrow-left me-2"></i> Back to All Events
            </a>
        </div>

        <div class="row g-5">

            <!-- Left Column - Image & Basic Info -->
            <div class="col-lg-7">
                <img src="@Model.ImageUrl"
                     class="hero-image w-100"
                     alt="@Model.Name"
                     onerror="this.src='https://placehold.co/800x520?text=Event+Image'" />

                <div class="mt-4 d-flex flex-wrap gap-3">
                    <span class="badge bg-primary badge-custom">
                        <i class="bi bi-tag me-1"></i> @Model.Category?.Name
                    </span>
                    @if (Model.IsFree)
                    {
                        <span class="badge bg-success badge-custom">Free Event</span>
                    }
                    else
                    {
                        <span class="badge bg-warning text-dark badge-custom">
                            ৳ @Model.RegistrationFee
                        </span>
                    }
                </div>
            </div>

            <!-- Right Column - Event Details -->
            <div class="col-lg-5">
                <div class="event-header">
                    <h1 class="display-5 fw-bold mb-3">@Model.Name</h1>

                    <div class="d-flex align-items-center gap-3 mb-4 text-muted">
                        <div>
                            <i class="bi bi-calendar3"></i>
                            <span class="ms-2">@Model.StartDate.ToString("dddd, dd MMMM yyyy")</span>
                        </div>
                        <div class="vr"></div>
                        <div>
                            <i class="bi bi-clock"></i>
                            <span class="ms-2">
                                @Model.StartDate.ToString("hh:mm tt") - @Model.EndDate.ToString("hh:mm tt")
                            </span>
                        </div>
                    </div>

                    <!-- Action Button -->
                    <a asp-controller="Studentregistration"
                       asp-action="CreateOrEdit"
                       class="btn btn-primary w-100 apply-btn mb-4">
                        <i class="bi bi-check-circle-fill me-2"></i>
                        Apply Now
                    </a>

                    <hr />

                    <!-- Key Information -->
                    <div class="row g-4 mt-2">
                        <div class="col-6">
                            <div class="info-card">
                                <div class="detail-label">Start Date</div>
                                <div class="detail-value">@Model.StartDate.ToString("dd MMM yyyy")</div>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="info-card">
                                <div class="detail-label">End Date</div>
                                <div class="detail-value">@Model.EndDate.ToString("dd MMM yyyy")</div>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="info-card">
                                <div class="detail-label">Meals Offered</div>
                                <div class="detail-value">@Model.MealsOffered</div>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="info-card">
                                <div class="detail-label">Status</div>
                                <div class="detail-value">
                                    @if (Model.EndDate < DateTime.Now)
                                    {
                                        <span class="text-danger">Completed</span>
                                    }
                                    else if (Model.StartDate > DateTime.Now)
                                    {
                                        <span class="text-success">Upcoming</span>
                                    }
                                    else
                                    {
                                        <span class="text-warning">Ongoing</span>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Full Description -->
            <div class="col-12">
                <div class="info-card">
                    <h4 class="fw-semibold mb-4">
                        <i class="bi bi-info-circle me-2 text-primary"></i>
                        About This Event
                    </h4>
                    <div class="lead text-secondary" style="line-height: 1.8;">
                        @Html.Raw(Model.Description?.Replace("\n", "<br/>") ?? "No detailed description available.")
                    </div>
                </div>
            </div>

        </div>

        <!-- Additional Info / Organizer -->
        <div class="row mt-5">
            <div class="col-lg-8">
                <div class="info-card">
                    <h5 class="fw-semibold mb-3">Organizer Information</h5>
                    <p class="text-muted">
                        This event is organized by the EventsMS team.
                        For any queries, feel free to contact our support.
                    </p>
                </div>
            </div>
            <div class="col-lg-4">
                <div class="info-card text-center">
                    <i class="bi bi-people-fill display-5 text-primary mb-3"></i>
                    <h5 class="fw-semibold">Limited Seats</h5>
                    <p class="text-muted small">Register early to secure your spot</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Footer (Simple) -->
    <footer class="bg-light py-5 mt-5 border-top">
        <div class="container text-center text-muted small">
            &copy; @DateTime.Now.Year EventsMS. All rights reserved.
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        // Dark mode support (same as Index page)
        const html = document.documentElement;
        const savedTheme = localStorage.getItem('theme') || 'light';
        html.setAttribute('data-bs-theme', savedTheme);

        // Optional: Add share buttons or more interactivity later
    </script>
</body>
</html>