@model IEnumerable<EventsMS.Models.Menu>
@{
    ViewData["Title"] = "Menu List";
}

<div class="container-fluid px-0 mt-4">
    <!-- Page Header -->
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-3">
        <div>
            <h2 class="fw-semibold text-dark mb-1">Menu Management</h2>
            <p class="text-secondary mb-0">Manage your website navigation menus</p>
        </div>
        <a asp-action="CreateOrEdit" class="btn btn-primary rounded-pill px-4 py-2 shadow-sm">
            <i class="bi bi-plus-circle me-2"></i>
            Create New Menu
        </a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light border-bottom">
                        <tr>
                            <th width="60" class="ps-4">#</th>
                            <th>Title</th>
                            <th>URL</th>
                            <th>Parent Menu</th>
                            <th width="120">Sort Order</th>
                            <th width="120">Status</th>
                            <th width="220" class="text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            int count = 1;
                        }
                        @foreach (var item in Model.OrderBy(x => x.SortOrder))
                        {
                            <tr>
                                <td class="ps-4 fw-medium text-secondary">@count</td>
                                <td>
                                    <span class="fw-semibold">@item.Title</span>
                                </td>
                                <td class="font-monospace text-secondary small">
                                    @item.Url
                                </td>
                                <td class="text-secondary">
                                    @if (item.Parent != null)
                                    {
                                        <span>@item.Parent.Title</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">—</span>
                                    }
                                </td>
                                <td>
                                    <span class="badge bg-light text-dark border">@item.SortOrder</span>
                                </td>
                                <td>
                                    @if (item.IsActive)
                                    {
                                        <span class="badge bg-success rounded-pill px-3 py-2">
                                            <i class="bi bi-check-circle me-1"></i> Active
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger rounded-pill px-3 py-2">
                                            <i class="bi bi-x-circle me-1"></i> Inactive
                                        </span>
                                    }
                                </td>
                                <td class="text-end pe-4">
                                    <div class="d-flex gap-2 justify-content-end flex-wrap">
                                        <!-- Details Button - Unique & Professional Design -->
                                        <a asp-action="Details" asp-route-id="@item.Id"
                                           class="btn btn-sm btn-outline-info rounded-pill px-3 d-flex align-items-center gap-1">
                                            <i class="bi bi-info-circle"></i>
                                            <span>Details</span>
                                        </a>

                                        <a asp-action="CreateOrEdit" asp-route-id="@item.Id"
                                           class="btn btn-sm btn-outline-primary rounded-pill px-3">
                                            <i class="bi bi-pencil-square me-1"></i> Edit
                                        </a>

                                        <a asp-action="Delete" asp-route-id="@item.Id"
                                           class="btn btn-sm btn-outline-danger rounded-pill px-3"
                                           onclick="return confirm('Are you sure you want to delete this menu item?')">
                                            <i class="bi bi-trash me-1"></i> Delete
                                        </a>
                                    </div>
                                </td>
                            </tr>
                            count++;
                        }
                    </tbody>
                </table>
            </div>

            @if (!Model.Any())
            {
                <div class="text-center py-5">
                    <i class="bi bi-list-nested display-1 text-secondary opacity-25"></i>
                    <h5 class="mt-3 text-secondary">No menus found</h5>
                    <p class="text-secondary">Create your first menu item to get started.</p>
                    <a asp-action="CreateOrEdit" class="btn btn-primary mt-3 rounded-pill">
                        <i class="bi bi-plus-circle me-2"></i>Create New Menu
                    </a>
                </div>
            }
        </div>
    </div>
</div>

<style>
    .table th {
        font-weight: 600;
        color: #495057;
        font-size: 0.95rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .table td {
        vertical-align: middle;
    }

    .font-monospace {
        font-family: 'SF Mono', Monaco, 'Cascadia Mono', 'Roboto Mono', Consolas, monospace;
    }

    .card {
        border-radius: 16px;
        overflow: hidden;
    }

    /* Unique & Professional Details Button Styling */
    .btn-outline-info {
        border-color: #0ea5e9;
        color: #0ea5e9;
        transition: all 0.25s ease;
    }

        .btn-outline-info:hover {
            background-color: #0ea5e9;
            color: white;
            border-color: #0ea5e9;
            transform: translateY(-1px);
        }

    .btn-outline-primary, .btn-outline-danger {
        transition: all 0.25s ease;
    }

        .btn-outline-primary:hover {
            background-color: #0d6efd;
            color: white;
            border-color: #0d6efd;
        }

        .btn-outline-danger:hover {
            background-color: #dc3545;
            color: white;
            border-color: #dc3545;
        }

    /* Hover effect on table rows */
    .table-hover tbody tr:hover {
        background-color: rgba(0, 123, 255, 0.03);
    }

    /* Dark mode support */
    [data-bs-theme="dark"] .table-light {
        background-color: #2b2f38 !important;
    }

    [data-bs-theme="dark"] .table th {
        color: #adb5bd;
    }

    [data-bs-theme="dark"] .btn-outline-info {
        border-color: #67e8f9;
        color: #67e8f9;
    }

        [data-bs-theme="dark"] .btn-outline-info:hover {
            background-color: #67e8f9;
            color: #0f172a;
        }
</style>