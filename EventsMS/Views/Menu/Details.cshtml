@model EventsMS.Models.Menu

@{
    ViewData["Title"] = "Menu Details";
}

<div class="container-fluid px-0 mt-4">
    <div class="card shadow border-0 overflow-hidden" style="border-radius: 16px; background: var(--card-bg);">

        <!-- Header -->
        <div class="card-header py-4 px-5 border-0 d-flex justify-content-between align-items-center"
             style="background: linear-gradient(135deg, #0d6efd, #0b5ed7); color: white;">
            <div class="d-flex align-items-center">
                <i class="bi bi-list-ul fs-3 me-3"></i>
                <h4 class="mb-0 fw-semibold">Menu Details</h4>
            </div>

            <div class="d-flex gap-2">
                <a asp-action="CreateOrEdit" asp-route-id="@Model.Id"
                   class="btn btn-light btn-sm px-4">
                    <i class="bi bi-pencil-square me-2"></i> Edit Menu
                </a>
                <a asp-action="Index" class="btn btn-outline-light btn-sm px-4">
                    <i class="bi bi-arrow-left me-2"></i> Back to List
                </a>
            </div>
        </div>

        <div class="card-body p-5">

            <!-- Main Information -->
            <div class="row g-5">

                <!-- Left Column - Details -->
                <div class="col-lg-7">
                    <h5 class="fw-bold text-muted mb-4 pb-2 border-bottom" style="border-bottom-color: var(--border) !important;">
                        Menu Information
                    </h5>

                    <div class="detail-grid">
                        <div class="detail-row">
                            <span class="detail-label">Title</span>
                            <span class="detail-value fw-semibold">@Model.Title</span>
                        </div>
                        <div class="detail-row">
                            <span class="detail-label">URL</span>
                            <span class="detail-value font-monospace text-primary">@Model.Url</span>
                        </div>
                        <div class="detail-row">
                            <span class="detail-label">Parent Menu</span>
                            <span class="detail-value">
                                @(Model.Parent != null ? Model.Parent.Title : "<span class='text-muted'>Root / Top Level Menu</span>")
                            </span>
                        </div>
                        <div class="detail-row">
                            <span class="detail-label">Sort Order</span>
                            <span class="detail-value">@Model.SortOrder</span>
                        </div>
                        <div class="detail-row">
                            <span class="detail-label">Status</span>
                            <span class="detail-value">
                                @if (Model.IsActive)
                                {
                                    <span class="badge bg-success px-3 py-2 fs-6">
                                        <i class="bi bi-check-circle me-1"></i> Active
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-danger px-3 py-2 fs-6">
                                        <i class="bi bi-x-circle me-1"></i> Inactive
                                    </span>
                                }
                            </span>
                        </div>
                    </div>
                </div>

                <!-- Right Column - Quick Summary -->
                <div class="col-lg-5">
                    <div class="bg-light p-4 rounded-3 h-100" style="background: rgba(var(--primary-rgb), 0.05) !important;">
                        <h6 class="fw-bold mb-3 text-primary">
                            <i class="bi bi-info-circle me-2"></i> Quick Overview
                        </h6>
                        <div class="d-flex justify-content-between mb-3">
                            <span class="text-muted">Menu Level</span>
                            <strong>@(Model.Parent == null ? "Top Level" : "Sub Menu")</strong>
                        </div>
                        <div class="d-flex justify-content-between">
                            <span class="text-muted">Child Menus</span>
                            <strong>@(Model.Children?.Count ?? 0)</strong>
                        </div>
                    </div>
                </div>
            </div>

            <hr class="my-5" style="border-color: var(--border) !important;" />

            <!-- Child Menus Section -->
            <div>
                <div class="d-flex align-items-center justify-content-between mb-4">
                    <h5 class="fw-bold mb-0">
                        <i class="bi bi-diagram-3 me-2 text-primary"></i>
                        Child Menus
                    </h5>
                    <span class="badge bg-primary fs-6">@(Model.Children?.Count ?? 0) Sub Menus</span>
                </div>

                @if (Model.Children != null && Model.Children.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>Title</th>
                                    <th>URL</th>
                                    <th class="text-center">Sort Order</th>
                                    <th class="text-center">Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var child in Model.Children.OrderBy(x => x.SortOrder))
                                {
                                    <tr>
                                        <td class="fw-medium">@child.Title</td>
                                        <td class="font-monospace text-muted">@child.Url</td>
                                        <td class="text-center">
                                            <span class="badge bg-secondary">@child.SortOrder</span>
                                        </td>
                                        <td class="text-center">
                                            @if (child.IsActive)
                                            {
                                                <span class="badge bg-success">Active</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-danger">Inactive</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-center py-5">
                        <i class="bi bi-folder-x display-4 text-muted mb-3 d-block"></i>
                        <p class="text-muted mb-0">No child menus available under this menu.</p>
                    </div>
                }
            </div>
        </div>

        <!-- Footer Actions -->
        <div class="card-footer bg-white py-4 px-5 border-0 d-flex justify-content-end gap-3">
            <a asp-action="Index" class="btn btn-outline-secondary px-5">
                <i class="bi bi-arrow-left me-2"></i> Back to Menu List
            </a>
            <a asp-action="CreateOrEdit" asp-route-id="@Model.Id"
               class="btn btn-primary px-5">
                <i class="bi bi-pencil-square me-2"></i> Edit This Menu
            </a>
        </div>
    </div>
</div>

<style>
    .detail-grid {
        display: grid;
        gap: 1.25rem;
    }

    .detail-row {
        display: flex;
        flex-wrap: wrap;
        gap: 1rem;
        padding-bottom: 1rem;
        border-bottom: 1px solid var(--border);
    }

        .detail-row:last-child {
            border-bottom: none;
            padding-bottom: 0;
        }

    .detail-label {
        min-width: 140px;
        font-weight: 600;
        color: var(--text-secondary);
    }

    .detail-value {
        flex: 1;
        color: var(--text-primary);
    }

    .table th {
        font-weight: 600;
        text-transform: uppercase;
        font-size: 0.85rem;
        letter-spacing: 0.5px;
    }

    .card {
        transition: all 0.3s ease;
    }

        .card:hover {
            box-shadow: 0 15px 30px rgba(0, 0, 0, 0.08);
        }
</style>