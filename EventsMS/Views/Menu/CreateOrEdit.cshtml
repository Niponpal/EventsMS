@model EventsMS.Models.Menu

@{
    ViewData["Title"] = Model.Id == 0 ? "Create Menu" : "Edit Menu";
}

<div class="container-fluid px-0 mt-4">
    <div class="card shadow border-0 overflow-hidden" style="border-radius: 16px;">

        <!-- Card Header -->
        <div class="card-header py-4 px-5 bg-primary text-white border-0">
            <div class="d-flex align-items-center">
                <i class="bi bi-list-ul fs-3 me-3"></i>
                <h4 class="mb-0 fw-semibold">
                    @(Model.Id == 0 ? "Create New Menu" : "Edit Menu")
                </h4>
            </div>
        </div>

        <div class="card-body p-5">
            <form asp-action="CreateOrEdit" method="post">
                <input type="hidden" asp-for="Id" />

                <!-- Validation Summary -->
                <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-4" role="alert"></div>

                <div class="row g-4">

                    <!-- Title -->
                    <div class="col-md-6">
                        <label asp-for="Title" class="form-label fw-semibold text-dark"></label>
                        <input asp-for="Title" class="form-control form-control-lg shadow-sm"
                               placeholder="Enter menu title (e.g. Student Registration)" />
                        <span asp-validation-for="Title" class="text-danger small mt-1"></span>
                    </div>

                    <!-- URL -->
                    <div class="col-md-6">
                        <label asp-for="Url" class="form-label fw-semibold text-dark"></label>
                        <input asp-for="Url" class="form-control form-control-lg shadow-sm"
                               placeholder="/StudentRegistration/Index" />
                        <span asp-validation-for="Url" class="text-danger small mt-1"></span>
                        <small class="text-muted">Example: /StudentRegistration/Index or /Events/Index</small>
                    </div>

                    <!-- Parent Menu -->
                    <div class="col-md-6">
                        <label class="form-label fw-semibold text-dark">Parent Menu</label>
                        <select asp-for="ParentId" asp-items="ViewBag.ParentMenus" class="form-select form-select-lg shadow-sm">
                            <option value="">-- No Parent (Top Level Menu) --</option>
                        </select>
                        <span asp-validation-for="ParentId" class="text-danger small mt-1"></span>
                    </div>

                    <!-- Sort Order -->
                    <div class="col-md-6">
                        <label asp-for="SortOrder" class="form-label fw-semibold text-dark">Sort Order</label>
                        <input asp-for="SortOrder" type="number" min="0"
                               class="form-control form-control-lg shadow-sm" placeholder="0" />
                        <span asp-validation-for="SortOrder" class="text-danger small mt-1"></span>
                    </div>

                    <!-- Is Active -->
                    <div class="col-12">
                        <div class="form-check form-switch form-switch-lg">
                            <input asp-for="IsActive" class="form-check-input" type="checkbox" role="switch" />
                            <label asp-for="IsActive" class="form-check-label fw-semibold">
                                Is Active <span class="text-success">(Menu will be visible)</span>
                            </label>
                        </div>
                    </div>

                </div>

                <!-- Form Actions -->
                <div class="d-flex flex-wrap justify-content-end gap-3 mt-5 pt-4 border-top">
                    <a asp-action="Index" class="btn btn-outline-secondary btn-lg px-5 rounded-pill">
                        <i class="bi bi-arrow-left me-2"></i> Cancel
                    </a>
                    <button type="submit" class="btn btn-primary btn-lg px-5 rounded-pill shadow-sm">
                        <i class="bi bi-check-circle me-2"></i>
                        @(Model.Id == 0 ? "Create Menu" : "Update Menu")
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

<style>
    .card {
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
    }

    .form-control:focus,
    .form-select:focus {
        border-color: #0d6efd;
        box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.15);
    }

    .form-switch .form-check-input {
        width: 3.5em;
        height: 1.8em;
    }

    .btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(13, 110, 253, 0.3);
    }
</style>